#!/bin/sh

protected_branches="main dev stage"
current_branch=$(git rev-parse --abbrev-ref HEAD)

# Block direct push to protected branches
for branch in $protected_branches; do
  if [ "$current_branch" = "$branch" ]; then
    echo ""
    echo "Direct push to '$current_branch' is not allowed."
    echo "  Please create a Pull Request and merge your changes instead."
    echo ""
    exit 1
  fi
done

# Enforce branch naming convention
branch_regex="^(feature|bugfix|hotfix|chore|release|update|ui)/[a-z0-9._-]+$"

if ! echo "$current_branch" | grep -Eq "$branch_regex"; then
  echo ""
  echo "Invalid branch name: '$current_branch'"
  echo ""
  echo "Allowed format:"
  echo "  feature/xyz"
  echo "  bugfix/xyz"
  echo "  hotfix/xyz"
  echo "  chore/xyz"
  echo "  release/xyz"
  echo "  update/xyz"
  echo "  ui/xyz"
  echo ""
  exit 1
fi

exit 0
